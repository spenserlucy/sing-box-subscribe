        "download_detour": "Proxy",
        "tag": "USRule3",
        "url": "https://raw.githubusercontent.com/senshinya/singbox_ruleset/main/rule/GoogleVoice/GoogleVoice.srs"
      },
      {
        "type": "remote",
        "format": "binary",
        "download_detour": "Proxy",
        "tag": "USRule4",
