{
  "log": {
    "disabled": false,
    "level": "info",
    "timestamp": true
  },
  "experimental": {
    "cache_file": {
      "enabled": true,
      "path": "cache.db",
      "cache_id": "my_profile2",
      "store_fakeip": true
    },
    "clash_api": {
      "external_ui": "ui",
      "external_controller": "0.0.0.0:9090",
      "external_ui_download_detour": "Proxy",
      "default_mode": "rule"
    }
  },
  "dns": {
    "servers": [
      {
        "tag": "google",
        "address": "tls://8.8.8.8",
        "detour": "Proxy"
      },
      {
        "tag": "fallback",
        "address": "8.8.8.8",
        "address_resolver": "google",
        "detour": "Proxy"
      },
      {
        "tag": "local-dns",
        "address": "223.5.5.5",
        "detour": "direct"
      },
      {
        "tag": "fakeip-dns",
        "address": "fakeip"
      },
      {
        "tag": "block-dns",
        "address": "rcode://success"
      }
    ],
    "rules": [
      {
        "outbound": "any",
        "server": "local-dns"
      },
      {
        "rule_set": [
          "BinOKX0",
          "BinOKX1"
        ],
        "server": "fakeip-dns"
      },
      {
        "rule_set": [
          "USRule0",
          "USRule1",
          "USRule2",
          "USRule3",
          "USRule4"
        ],
        "server": "fakeip-dns"
      },
      {
        "rule_set": [
          "China0",
          "China1",
          "China2",
          "China3",
          "China4"
        ],
        "server": "local-dns"
      },
      {
        "rule_set": [
          "Ad0"
        ],
        "server": "block-dns"
      },
      {
        "query_type": [
          "A"
        ],
        "rewrite_ttl": 1,
        "server": "fakeip-dns"
      }
    ],
    "strategy": "prefer_ipv4",
    "fakeip": {
      "enabled": true,
      "inet4_range": "198.18.0.0/15"
    }
  },
  "inbounds": [
    {
      "auto_route": true,
      "domain_strategy": "prefer_ipv4",
      "endpoint_independent_nat": true,
      "inet4_address": "172.19.0.1/30",
      "inet6_address": "2001:0470:f9da:fdfa::1/64",
      "mtu": 9000,
      "sniff": true,
      "sniff_override_destination": true,
      "stack": "system",
      "strict_route": true,
      "type": "tun"
    },
    {
      "domain_strategy": "prefer_ipv4",
      "listen": "127.0.0.1",
      "listen_port": 2333,
      "sniff": true,
      "sniff_override_destination": true,
      "tag": "socks-in",
      "type": "socks",
      "users": []
    },
    {
      "domain_strategy": "prefer_ipv4",
      "listen": "127.0.0.1",
      "listen_port": 2334,
      "sniff": true,
      "sniff_override_destination": true,
      "tag": "mixed-in",
      "type": "mixed",
      "users": []
    }
  ],
  "route": {
    "rule_set": [
      {
        "type": "remote",
        "format": "binary",
