        "url": "https://raw.githubusercontent.com/senshinya/singbox_ruleset/main/rule/Advertising/Advertising.srs"
      }
    ],
    "rules": [
      {
        "protocol": "dns",
        "outbound": "dns-out"
      },
      {
        "ip_is_private": true,
        "outbound": "direct"
      },
      {
        "clash_mode": "direct",
        "outbound": "direct"
      },
      {
        "clash_mode": "global",
        "outbound": "GLOBAL"
      },
      {
        "rule_set": [
          "BinOKX0",
          "BinOKX1"
        ],
        "outbound": "BinOKX"
      },
      {
        "rule_set": [
          "USRule0",
          "USRule1",
          "USRule2",
          "USRule3",
          "USRule4"
        ],
        "outbound": "USRule"
      },
      {
        "rule_set": [
          "China0",
          "China1",
          "China2",
          "China3",
          "China4"
        ],
        "outbound": "direct"
      },
      {
        "rule_set": [
          "Ad0"
        ],
        "outbound": "block"
      },
      {
        "ip_is_private": true,
        "outbound": "direct"
      }
    ],
    "auto_detect_interface": true,
    "final": "Proxy"
  },
 "outbounds": [
