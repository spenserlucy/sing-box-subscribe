{
  "log": {
    "disabled": false,
    "level": "info",
    "timestamp": false
  },
"experimental": {
    "cache_file": {
        "enabled": true,
        "path": "cache.db",
        "cache_id": "ctc"
    },
    "clash_api": {
      "external_controller": "127.0.0.1:9090",
      "external_ui": "ui",
      "secret": "",
      "external_ui_download_url": "https://ghp.ci/https://github.com/MetaCubeX/Yacd-meta/archive/gh-pages.zip",
      "external_ui_download_detour": "out-direct",
      "default_mode": "Rule"
    }
  },
  "dns": {
    "servers": [
      {
        "tag": "dns_resolver-tx",
        "address": "119.29.29.29",
        "detour": "out-direct"
      },
      {
        "tag": "local-dns",
        "address": "https://120.53.53.53/dns-query",
        "address_resolver": "dns_resolver-tx",
        "detour": "out-direct"
      },
      {
        "tag": "google",
        "address": "https://162.159.36.1/dns-query",
        "address_resolver": "dns_resolver-tx",
        "address_strategy": "ipv4_only",
        "detour": "Proxy"
      },
      {
        "tag": "block",
        "address": "rcode://refused"
      }
    ],
    "rules": [
      {
        "outbound": "any",
        "server": "dns_resolver-tx"
      },
      {
        "query_type": "HTTPS",
        "server": "block"
      },
      {
        "outbound": "google",
        "server": "google"
      },
      {
        "clash_mode": "Direct",
        "server": "local-dns"
      },
      {
        "clash_mode": "Global",
        "server": "google"
      },
      {
        "rule_set": [
          "BinOKX0",
          "BinOKX1"
        ],
        "server": "google"
      },
      {
        "rule_set": [
          "USRule0",
          "USRule1",
          "USRule2",
          "USRule3",
          "USRule4"
        ],
        "server": "google"
      },
      {
        "rule_set": [
          "Video0"
        ],
        "server": "google"
      },
      {
        "rule_set": [
          "China0",
          "China1",
          "China2",
          "China3",
          "China4"
        ],
        "server": "local-dns"
      },
      {
        "rule_set": [
          "geosite-cn",
          "geosite-geolocation-cn"
        ],
        "server": "dns-direct-tx"
      }
    ],
    "client_subnet": "42.239.205.0",
    "strategy": "ipv4_only",
    "final": "google"
  },
  "inbounds": [
    {
      "tag": "tun-in",
      "type": "tun",
      "interface_name": "singbox",
      "address": [
        "172.19.0.1/30"
      ],
      "mtu": 9000,
      "stack": "system",
      "auto_route": true,
      "sniff": true,
      "sniff_override_destination": true,
      "strict_route": true,
      "platform": {
        "http_proxy": {
          "enabled": false,
          "server": "127.0.0.1",
          "server_port": 7890
        }
      }
    },
    {
      "tag": "socks-in",
      "type": "socks",
      "listen": "::",
      "listen_port": 5319
    }
  ],
  "route": {
    "rules": [
      {
        "inbound": "socks-in",
        "outbound": "Proxy"
      },
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          {
            "protocol": "dns"
          },
          {
            "port": 53
          }
        ],
        "outbound": "out-dns"
      },
      {
        "rule_set": "geosite-gfw",
        "outbound": "Proxy"
      },
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          {
            "rule_set": "geosite-geolocation-!cn"
          },
          {
            "rule_set": "geoip-cn",
            "invert": true
          }
        ],
        "outbound": "Proxy"
      },
      {
        "protocol": "quic",
        "outbound": "block"
      },
      {
        "clash_mode": "Direct",
        "outbound": "out-direct"
      },
      {
        "clash_mode": "Global",
        "outbound": "Proxy"
      },
      {
        "rule_set": [
          "BinOKX0",
          "BinOKX1"
        ],
        "outbound": "BinOKX"
      },
      {
        "rule_set": [
          "Video0"
        ],
        "outbound": "Video"
      },
      {
        "rule_set": [
          "USRule0",
          "USRule1",
          "USRule2",
          "USRule3",
          "USRule4"
        ],
        "outbound": "USRule"
      },
      {
        "rule_set": [
          "China0",
          "China1",
          "China2",
          "China3",
          "China4",
          "geosite-geolocation-cn",
          "geosite-cn"
        ],
        "outbound": "out-direct"
      },
      {
        "ip_is_private": true,
        "outbound": "out-direct"
      },
      {
        "rule_set": "geosite-geolocation-!cn",
        "outbound": "Proxy"
      }
    ],
    "rule_set": [
      {
        "type": "remote",
        "format": "binary",
        "download_detour": "out-direct",
