    "rules": [
      {
        "protocol": "dns",
        "outbound": "dns-out"
      },
      {
        "port": 53,
        "outbound": "dns-out"
      },
      {
        "clash_mode": "direct",
        "outbound": "direct"
      },
      {
        "clash_mode": "global",
        "outbound": "Proxy"
      },
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          {
            "port": 853
          },
          {
            "network": "udp",
            "port": 443
          },
          {
            "protocol": "stun"
          }
        ],
        "outbound": "block"
      },
      {
        "rule_set": [
          "BinOKX0",
          "BinOKX1"
        ],
        "outbound": "BinOKX"
      },
      {
        "rule_set": [
          "USRule0",
          "USRule1",
          "USRule2",
          "USRule3",
          "USRule4"
        ],
        "outbound": "USRule"
      },
      {
        "rule_set": [
          "Media0"
        ],
        "outbound": "Media"
      },
      {
        "rule_set": [
          "China0",
          "China1",
          "China2",
          "China3",
          "China4"
        ],
        "outbound": "direct"
      },
      {
        "ip_is_private": true,
        "outbound": "direct"
      }
    ],
    "auto_detect_interface": true,
    "final": "Proxy"
  },
 "outbounds": [
 {
      "tag": "Proxy",
      "outbounds": [
        "MapleCloud",
        "CTC200",
        "Select"
