{
  "log": {
    "disabled": false,
    "level": "info",
    "timestamp": true
  },
"experimental": {
    "clash_api": {
      "external_controller": "127.0.0.1:9090",
      "external_ui": "ui",
      "secret": "",
      "external_ui_download_url": "https://ghp.ci/https://github.com/MetaCubeX/Yacd-meta/archive/gh-pages.zip",
      "external_ui_download_detour": "direct",
      "default_mode": "rule"
    }
  },
  "dns": {
    "servers": [
      {
        "tag": "google",
        "address": "tls://8.8.8.8",
        "address_strategy": "prefer_ipv4",
        "detour": "Proxy"
      },
      {
        "tag": "fallback",
        "address": "8.8.8.8",
        "address_resolver": "google",
        "address_strategy": "prefer_ipv4",
        "detour": "Proxy"
      },
      {
        "tag": "local-dns",
        "address": "223.5.5.5",
        "address_strategy": "prefer_ipv4",
        "detour": "direct"
      },
      {
        "tag": "fakeip-dns",
        "address": "fakeip"
      },
      {
        "tag": "block-dns",
        "address": "rcode://success"
      }
    ],
    "rules": [
      {
        "outbound": "any",
        "server": "local-dns",
         "disable_cache": true
      },
      {
        "clash_mode": "direct",
        "server": "local-dns"
      },
      {
        "clash_mode": "global",
        "server": "google"
      },
      {
         "domain_keyword": "ntp",
         "server": "local-dns"
      },
      {
        "rule_set": [
          "BinOKX0",
          "BinOKX1"
        ],
        "server": "fakeip-dns"
      },
      {
        "rule_set": [
          "USRule0",
          "USRule1",
          "USRule2",
          "USRule3",
          "USRule4"
        ],
        "server": "fakeip-dns"
      },
      {
        "rule_set": [
          "Media0"
        ],
        "server": "fakeip-dns"
      },
      {
        "rule_set": [
          "China0",
          "China1",
          "China2",
          "China3",
          "China4"
        ],
        "server": "local-dns"
      },
      {
        "query_type": [
          "A",
          "AAAA"
        ],
        "rewrite_ttl": 1,
        "server": "fakeip-dns"
      }
    ],
    "final": "local-dns",
    "reverse_mapping": true,
    "independent_cache": true,
    "fakeip": {
        "enabled": true,
        "inet4_range": "198.18.0.0/15",
        "inet6_range": "fc00::/18"
    }
  },
  "inbounds": [
    {
      "tag": "tun",
      "type": "tun",
      "address": [
        "172.19.0.0/30",
        "fdfe:dcba:9876::0/126"
      ],
      "stack": "system",
      "auto_route": true,
      "strict_route": true,
      "sniff": true,
      "platform": {
        "http_proxy": {
          "enabled": false,
          "server": "127.0.0.1",
          "server_port": 7890
        }
      }
    },
    {
      "tag": "mixed",
      "type": "mixed",
      "listen": "127.0.0.1",
      "listen_port": 7890,
      "sniff": true
    }
  ],
  "route": {
    "rule_set": [
      {
        "type": "remote",
        "format": "binary",
        "download_detour": "direct",
        "tag": "BinOKX0",
        "url": "https://ghp.ci/https://raw.githubusercontent.com/senshinya/singbox_ruleset/main/rule/Binance/Binance.srs"
      },
      {
        "type": "remote",
